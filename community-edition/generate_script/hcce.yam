    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (size(variables.pod.spec.volumes) == 1 &&
      variables.pod.spec.volumes[0].name == 'runner-tmp' &&
      quantity(variables.pod.spec.volumes[0].emptyDir.sizeLimit).compareTo(quantity('64Mi')) == 0 &&
      (!has(variables.pod.spec.volumes[0].emptyDir.medium) || variables.pod.spec.volumes[0].emptyDir.medium == '') &&
      !has(variables.pod.spec.volumes[0].awsElasticBlockStore) &&
      !has(variables.pod.spec.volumes[0].azureDisk) &&
      !has(variables.pod.spec.volumes[0].azureFile) &&
      !has(variables.pod.spec.volumes[0].cephfs) &&
      !has(variables.pod.spec.volumes[0].cinder) &&
      !has(variables.pod.spec.volumes[0].configMap) &&
      !has(variables.pod.spec.volumes[0].csi) &&
      !has(variables.pod.spec.volumes[0].downwardAPI) &&
      !has(variables.pod.spec.volumes[0].ephemeral) &&
      !has(variables.pod.spec.volumes[0].fc) &&
      !has(variables.pod.spec.volumes[0].flexVolume) &&
      !has(variables.pod.spec.volumes[0].flocker) &&
      !has(variables.pod.spec.volumes[0].gcePersistentDisk) &&
      !has(variables.pod.spec.volumes[0].gitRepo) &&
      !has(variables.pod.spec.volumes[0].glusterfs) &&
      !has(variables.pod.spec.volumes[0].hostPath) &&
      !has(variables.pod.spec.volumes[0].image) &&
      !has(variables.pod.spec.volumes[0].iscsi) &&
      !has(variables.pod.spec.volumes[0].nfs) &&
      !has(variables.pod.spec.volumes[0].persistentVolumeClaim) &&
      !has(variables.pod.spec.volumes[0].photonPersistentDisk) &&
      !has(variables.pod.spec.volumes[0].portworxVolume) &&
      !has(variables.pod.spec.volumes[0].projected) &&
      !has(variables.pod.spec.volumes[0].quobyte) &&
      !has(variables.pod.spec.volumes[0].rbd) &&
      !has(variables.pod.spec.volumes[0].scaleIO) &&
      !has(variables.pod.spec.volumes[0].secret) &&
      !has(variables.pod.spec.volumes[0].storageos) &&
      !has(variables.pod.spec.volumes[0].vsphereVolume))
    message: runner Pod may mount only the bounded emptyDir scratch volume
    reason: Forbidden
  - expression: >-
      request.operation != 'DELETE' ||
      (has(request.options) &&
       has(request.options.preconditions) &&
       has(request.options.preconditions.uid) &&
       string(request.options.preconditions.uid) == string(oldObject.metadata.uid))
    message: runner Pod DELETE requires an exact UID precondition
    reason: Forbidden
---
apiVersion: admissionregistration.k8s.io/v1
kind: ValidatingAdmissionPolicyBinding
metadata:
  name: bot-runner-pods.yenhubs.org
spec:
  policyName: bot-runner-pods.yenhubs.org
  validationActions:
  - Deny
  matchResources:
    matchPolicy: Equivalent
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: hcce-bot-runners
    objectSelector: {}
---
########################################################################
######################   pgsql   #######################################
########################################################################
apiVersion: v1
kind: Service
metadata:
  name: pgsql
  namespace: $Namespace
spec:
  selector:
    app: pgsql
  ports:
    - name: postgresql
      protocol: TCP
      port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: pgsql
  namespace: $Namespace
  annotations:
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
spec:
  replicas: 1
  # pgsql-pvc is single-writer storage. Never run two PostgreSQL revisions.
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: pgsql
  template:
    metadata:
      labels:
        app: pgsql
    spec:
      automountServiceAccountToken: false
      containers:
        - name: postgresql
          image: $Container_Dockerhub_Username/postgres:$Container_Tag
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              memory: 1Gi
          ports:
            - name: postgresql
              containerPort: 5432
          env:
            - name: POSTGRES_USER
              valueFrom:
                secretKeyRef:
                  name: configs
                  key: DB_USER
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: configs
                  key: DB_PASS
            - name: POSTGRES_DB
              valueFrom:
                secretKeyRef:
                  name: configs
                  key: DB_NAME
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
          volumeMounts:
            - name: postgresql-data
              mountPath: /var/lib/postgresql/data
      volumes:
        - name: postgresql-data
          hostPath:
            path: /tmp/pgsql_data
---
####################################################################################
################################### pgbouncer ######################################
####################################################################################
apiVersion: apps/v1
kind: Deployment
metadata:
  name: pgbouncer
  namespace: $Namespace
  annotations:
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
spec:
  replicas: $PGBOUNCER_REPLICAS
  selector:
    matchLabels:
      app: pgbouncer
  minReadySeconds: 2
  template:
    metadata:
      labels:
        app: pgbouncer
      annotations:
        yenhubs.org/db-credential-checksum: "$DB_CREDENTIAL_CHECKSUM"
    spec:
      automountServiceAccountToken: false
      containers:
      - image: $Container_Dockerhub_Username/pgbouncer:$Container_Tag
        resources:
          requests:
            cpu: 10m
            memory: 16Mi
          limits:
            memory: 128Mi
        imagePullPolicy: IfNotPresent
        name: pgbouncer
        env:
        - name: MAX_CLIENT_CONN
          value: "10000"
        - name: DB_USER
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_USER
        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_PASS
        - name: DB_HOST
          value: pgsql
---
apiVersion: v1
kind: Service
metadata:
  name: pgbouncer
  namespace: $Namespace
spec:
  ports:
  - name: http
    port: 5432
    targetPort: 5432
  selector:
    app: pgbouncer
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: pgbouncer-t
  namespace: $Namespace
  annotations:
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
spec:
  replicas: $PGBOUNCER_T_REPLICAS
  selector:
    matchLabels:
      app: pgbouncer-t
  minReadySeconds: 2
  template:
    metadata:
      labels:
        app: pgbouncer-t
      annotations:
        yenhubs.org/db-credential-checksum: "$DB_CREDENTIAL_CHECKSUM"
    spec:
      automountServiceAccountToken: false
      containers:
      - image: $Container_Dockerhub_Username/pgbouncer:$Container_Tag
        resources:
          requests:
            cpu: 10m
            memory: 16Mi
          limits:
            memory: 128Mi
        imagePullPolicy: IfNotPresent
        name: pgbouncer-t
        env:
        - name: MAX_CLIENT_CONN
          value: "10000"
        - name: DB_USER
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_USER
        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_PASS
        - name: DB_HOST
          value: pgsql
        - name: POOL_MODE
          value: transaction
---
apiVersion: v1
kind: Service
metadata:
  name: pgbouncer-t
  namespace: $Namespace
spec:
  ports:
  - name: http
    port: 5432
    targetPort: 5432
  selector:
    app: pgbouncer-t
---
########################################################################
######################   hubs   ########################################
########################################################################
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hubs
  namespace: $Namespace
  annotations:
    cluster-autoscaler.kubernetes.io/safe-to-evict: "true"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: hubs
  minReadySeconds: 15
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 0
      maxSurge: 1
  template:
    metadata:
      labels:
        app: hubs
    spec:
      automountServiceAccountToken: false
      containers:
      - name: hubs
        image: $Container_Dockerhub_Username/hubs:$Container_Tag
        resources:
          requests:
            cpu: 10m
            memory: 16Mi
          limits:
            memory: 128Mi
        imagePullPolicy: IfNotPresent
        env:
        - name: turkeyCfg_thumbnail_server
          value: 'cors.$HUB_DOMAIN/nearspark'
        - name: turkeyCfg_base_assets_path
          value: https://assets.$HUB_DOMAIN/hubs/
        - name: turkeyCfg_non_cors_proxy_domains
          value: "$HUB_DOMAIN,assets.$HUB_DOMAIN,demo.hubsfoundation.org,*.demo.hubsfoundation.org"
        - name: turkeyCfg_reticulum_server
          value: $HUB_DOMAIN
        - name: turkeyCfg_cors_proxy_server
          value: cors.$HUB_DOMAIN
        - name: turkeyCfg_shortlink_domain
          value: $HUB_DOMAIN
        - name: turkeyCfg_tier
          value: p1
        livenessProbe:
          httpGet:
            path: https://localhost/healthz
            port: 8080
            scheme: HTTPS
          initialDelaySeconds: 20
          timeoutSeconds: 1
          periodSeconds: 120
---
apiVersion: v1
kind: Service
metadata:
  name: hubs
  namespace: $Namespace
  annotations:
    haproxy.org/server-ssl: "true"
spec:
  clusterIP: None
  ports:
  - name: https-hubs
    port: 8080
    targetPort: 8080
  selector:
    app: hubs
---
