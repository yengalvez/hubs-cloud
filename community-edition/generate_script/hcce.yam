      quantity(variables.container.resources.requests['cpu']).compareTo(quantity('25m')) == 0 &&
      quantity(variables.container.resources.requests['memory']).compareTo(quantity('128Mi')) == 0 &&
      size(variables.container.resources.limits) == 2 &&
      quantity(variables.container.resources.limits['cpu']).compareTo(quantity('500m')) == 0 &&
      quantity(variables.container.resources.limits['memory']).compareTo(quantity('512Mi')) == 0 &&
      (!has(variables.container.resources.claims) || size(variables.container.resources.claims) == 0) &&
      size(variables.container.volumeMounts) == 1 &&
      variables.container.volumeMounts[0].name == 'runner-tmp' &&
      variables.container.volumeMounts[0].mountPath == '/tmp' &&
      (!has(variables.container.volumeMounts[0].readOnly) || variables.container.volumeMounts[0].readOnly == false) &&
      !has(variables.container.volumeMounts[0].mountPropagation) &&
      !has(variables.container.volumeMounts[0].recursiveReadOnly) &&
      !has(variables.container.volumeMounts[0].subPath) &&
      !has(variables.container.volumeMounts[0].subPathExpr) &&
      variables.container.readinessProbe.exec.command == ['test', '-f', '/tmp/runner-ready'] &&
      variables.container.readinessProbe.failureThreshold == 2 &&
      variables.container.readinessProbe.initialDelaySeconds == 5 &&
      variables.container.readinessProbe.periodSeconds == 5 &&
      variables.container.readinessProbe.successThreshold == 1 &&
      variables.container.readinessProbe.timeoutSeconds == 2 &&
      !has(variables.container.readinessProbe.grpc) &&
