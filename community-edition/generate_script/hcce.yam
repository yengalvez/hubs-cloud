apiVersion: v1
kind: Namespace
metadata:
  name: "$Namespace"
  annotations:
    domain: "$HUB_DOMAIN"
    adm: "$ADM_EMAIL"
---
apiVersion: v1
kind: Namespace
metadata:
  name: hcce-bot-runners
  labels:
    pod-security.kubernetes.io/enforce: restricted
    pod-security.kubernetes.io/enforce-version: v1.34
    pod-security.kubernetes.io/audit: restricted
    pod-security.kubernetes.io/audit-version: v1.34
    pod-security.kubernetes.io/warn: restricted
    pod-security.kubernetes.io/warn-version: v1.34
---
########################################################################
###################### configs #########################################
########################################################################
apiVersion: v1
kind: Secret
metadata:
  name: configs
  namespace: "$Namespace"
stringData:
  NODE_COOKIE: "$NODE_COOKIE"
  HUB_DOMAIN: "$HUB_DOMAIN"
  DB_USER: "$DB_USER"
  DB_PASS: "$DB_PASS"
  DB_NAME: "$DB_NAME"
  DB_HOST: "$DB_HOST"
  DB_HOST_T: "$DB_HOST_T"
  SMTP_SERVER: "$SMTP_SERVER"
  SMTP_PORT: "$SMTP_PORT"
  SMTP_USER: "$SMTP_USER"
  SMTP_PASS: "$SMTP_PASS"
  ADM_EMAIL: "$ADM_EMAIL"
  PGRST_DB_URI: "$PGRST_DB_URI"
  GUARDIAN_KEY: "$GUARDIAN_KEY"
  PHX_KEY: "$PHX_KEY"
  SKETCHFAB_API_KEY: "$SKETCHFAB_API_KEY"
  TENOR_API_KEY: "$TENOR_API_KEY"
  BOT_ACCESS_KEY: "$BOT_ACCESS_KEY"
  BOT_RUNNER_ACCESS_KEY: "$BOT_RUNNER_ACCESS_KEY"
  BOT_ORCHESTRATOR_ACCESS_KEY: "$BOT_ORCHESTRATOR_ACCESS_KEY"
  DASHBOARD_ACCESS_KEY: "$DASHBOARD_ACCESS_KEY"
  OPENAI_API_KEY: "$OPENAI_API_KEY"
  PSQL: "$PSQL"
  PERMS_KEY: '$PERMS_KEY'
  PGRST_JWT_SECRET: '$PGRST_JWT_SECRET'
---
apiVersion: v1
kind: Secret
metadata:
  name: bot-images-pull
  namespace: "$Namespace"
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: "$BOT_IMAGE_PULL_CONFIG_JSON_BASE64"
---
apiVersion: v1
kind: Secret
metadata:
  name: bot-images-pull
  namespace: hcce-bot-runners
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: "$BOT_IMAGE_PULL_CONFIG_JSON_BASE64"
---
######################################################################################
###################################### ingress #######################################
######################################################################################
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ret
  namespace: $Namespace
  annotations:
    kubernetes.io/ingress.class: haproxy
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
    haproxy.org/ssl-redirect: "true"
    haproxy.org/response-set-header: |
      access-control-allow-origin "https://$HUB_DOMAIN"
    haproxy.org/path-rewrite: /api-internal(.*) /_drop_
spec:
  ingressClassName: haproxy
  tls:
  - hosts:
      - $HUB_DOMAIN
    secretName: cert-$HUB_DOMAIN
  - hosts:
      - assets.$HUB_DOMAIN
    secretName: cert-assets.$HUB_DOMAIN
  - hosts:
      - stream.$HUB_DOMAIN
    secretName: cert-stream.$HUB_DOMAIN
  - hosts:
      - cors.$HUB_DOMAIN
    secretName: cert-cors.$HUB_DOMAIN
  rules:
  - host: $HUB_DOMAIN
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: ret
            port:
              number: 4001
  - host: assets.$HUB_DOMAIN
    http:
      paths:
      - path: /files/
        pathType: Prefix
        backend:
          service:
            name: ret
            port:
              number: 4001
      - path: /http
        pathType: ImplementationSpecific  # haproxy's "Begin with"
        backend:
          service:
            name: ret
            port:
              number: 4001
      - path: /hubs
        pathType: Prefix
        backend:
          service:
            name: hubs
            port:
              number: 8080
      - path: /spoke
        pathType: Prefix
        backend:
          service:
            name: spoke
            port:
              number: 8080
  - host: cors.$HUB_DOMAIN
    http:
      paths:
      - path: /files/
        pathType: Prefix
        backend:
          service:
            name: ret
            port:
              number: 4001
      - path: /http
        pathType: ImplementationSpecific
        backend:
          service:
            name: ret
            port:
              number: 4001
      - path: /hubs
        pathType: Prefix
        backend:
          service:
            name: hubs
            port:
              number: 8080
      - path: /spoke
        pathType: Prefix
        backend:
          service:
            name: spoke
            port:
              number: 8080
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: dialog
  namespace: $Namespace
  annotations:
    kubernetes.io/ingress.class: haproxy
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
    haproxy.org/ssl-redirect: "true"
    haproxy.org/server-ssl: "true"
    haproxy.org/load-balance: "url_param roomId"
spec:
  ingressClassName: haproxy
  tls:
  - hosts:
      - stream.$HUB_DOMAIN
    secretName: cert-stream.$HUB_DOMAIN
  rules:
  - host: stream.$HUB_DOMAIN
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: dialog
            port:
              number: 4443
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: nearspark
  namespace: $Namespace
  annotations:
    kubernetes.io/ingress.class: haproxy
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
    haproxy.org/ssl-redirect: "true"
    haproxy.org/path-rewrite: /nearspark/(.*) /\1
spec:
  ingressClassName: haproxy
  tls:
  - hosts:
      - cors.$HUB_DOMAIN
    secretName: cert-cors.$HUB_DOMAIN
  rules:
  - host: cors.$HUB_DOMAIN
    http:
      paths:
      - path: /nearspark
        pathType: Prefix
        backend:
          service:
            name: nearspark
            port:
              number: 5000
---
##############################################################################################
############################################ reticulum #######################################
##############################################################################################
apiVersion: v1
kind: ConfigMap
metadata:
  name: ret-config
  namespace: $Namespace
data:
  config.toml.template: |
    [peerage]
    dns_name = "ret.<POD_NS>.svc.cluster.local"
    app_name = "ret"

    [ret."Elixir.Ret"]
    pool = "hubs"

    [ret."Elixir.RetWeb.Plugs.DashboardHeaderAuthorization"]
    dashboard_access_key = "<DASHBOARD_ACCESS_KEY>"

    # Legacy wire alias for RetNotice, SupportSubscription and Hub delete.
    # These are dashboard-administrative actions, so they intentionally share
    # the dashboard trust domain while retaining their existing header name.
    [ret."Elixir.RetWeb.Plugs.HeaderAuthorization"]
    header_value = "<DASHBOARD_ACCESS_KEY>"

    [ret."Elixir.Ret.DiscordClient"]
    client_id = ""
    client_secret = ""
    bot_token = ""

    [ret."Elixir.RetWeb.Endpoint".https]
    port = 4000
    certfile = "/ret/cert.pem"
    cacertfile = "/ret/cacert.pem"
    keyfile = "/ret/key.pem"

    [ret."Elixir.RetWeb.Endpoint"]
    allowed_origins = "*"
    secret_key_base = "<PHX_KEY>"
    allow_crawlers = true

    [ret."Elixir.RetWeb.Endpoint".secondary_url]

    [ret."Elixir.RetWeb.Endpoint".cors_proxy_url]
    host = "cors.<HUB_DOMAIN>"
    port = 443

    [ret."Elixir.RetWeb.Endpoint".imgproxy_url]
    host = "<IMG_PROXY>"
    port = 5000

    [ret."Elixir.RetWeb.Endpoint".assets_url]
    host = "assets.<DOMAIN>"
    port = 443

    [ret."Elixir.RetWeb.Endpoint".link_url]
    host = "hubs-link.local"

    [ret."Elixir.RetWeb.Endpoint".url]
    host = "<HUB_DOMAIN>"
    port = 443

    [ret."Elixir.RetWeb.Endpoint".static_url]
    host = "<HUB_DOMAIN>"

    [ret."Elixir.Ret.Repo"]
    username = "<DB_USER>"
    password = "<DB_PASS>"
    database = "<DB_NAME>"
    hostname = "<DB_HOST_T>"
    template = "template0"
    pool_size = 10
    port = 5432

    [ret."Elixir.Ret.SessionLockRepo"]
    username = "<DB_USER>"
    password = "<DB_PASS>"
    database = "<DB_NAME>"
    hostname = "<DB_HOST>"
    template = "template0"

    port = 5432

    [ret."Elixir.Ret.Locking".session_lock_db]
    username = "<DB_USER>"
    password = "<DB_PASS>"
    database = "<DB_NAME>"
    hostname = "<DB_HOST>"
    port = 5432

    [ret."Elixir.Ret.Habitat"]
    ip = "127.0.0.1"
    http_port = 9631

    [ret."Elixir.Ret.JanusLoadStatus"]
    default_janus_host = "stream.<DOMAIN>"
    janus_service_name = ""
    janus_admin_secret = ""
    janus_admin_port = 7000
    janus_port = 4443

    [ret."Elixir.Ret.Guardian"]
    secret_key = "<GUARDIAN_KEY>"
    issuer = "<HUB_DOMAIN>"

    [ret."Elixir.Ret.PermsToken"]
    perms_key = "<PERMS_KEY>"

    [ret."Elixir.Ret.OAuthToken"]
    oauth_token_key = ""

    [ret]
    bot_access_key = "<BOT_ACCESS_KEY>"
    bot_runner_access_key = "<BOT_RUNNER_ACCESS_KEY>"
    bot_orchestrator_access_key = "<BOT_ORCHESTRATOR_ACCESS_KEY>"
    bot_runner_recovery_epoch = "<BOT_RUNNER_RECOVERY_EPOCH>"
    max_active_bot_rooms = <MAX_ACTIVE_ROOMS>
    # pgrest_host = ""
    # ita_host = ""

    [ret."Elixir.Ret.BotOrchestrator"]
    endpoint = "http://bot-orchestrator.<POD_NS>:5001"
    access_key = "<BOT_ORCHESTRATOR_ACCESS_KEY>"

    [ret."Elixir.Ret.MediaResolver"]
    ytdl_host = "<YTDL_HOST>"
    photomnemonic_endpoint = "<PHOTOMNEMONIC>"
    sketchfab_api_key = "<SKETCHFAB_API_KEY>"
    tenor_api_key = "<TENOR_API_KEY>"

    [ret."Elixir.Ret.Speelycaptor"]
    speelycaptor_endpoint = "<SPEELYCAPTOR>"

    [ret."Elixir.Ret.PageOriginWarmer"]
    hubs_page_origin = "https://hubs.<POD_NS>:8080/hubs/pages"
    spoke_page_origin = "https://spoke.<POD_NS>:8080/spoke/pages"
    admin_page_origin = "https://hubs.<POD_NS>:8080/hubs/pages"
    insecure_ssl = true

    [ret."Elixir.Ret.HttpUtils"]
    insecure_ssl = true

    [ret."Elixir.Ret.Storage"]
    storage_path = "/storage"
    ttl = 172800
    host = "https://<HUB_DOMAIN>"
    quota_gb = "<STORAGE_QUOTA_GB>" # example: "12"
    # ^^^ has to be string or elixir throws (ArgumentError) argument error:erlang.byte_size(#), but why

    [ret."Elixir.RetWeb.Email"]
    from = "noreply@<HUB_DOMAIN>"

    [ret."Elixir.Ret.Mailer"]
    relay = "<SMTP_SERVER>"
    port = "<SMTP_PORT>"
    username = "<SMTP_USER>"
    password = "<SMTP_PASS>"

    server = "<SMTP_SERVER>" # deprecated - kept for old Reticulum/Bamboo compatibility.

    [ret."Elixir.Ret.Support"]
    slack_webhook_url = ""

    # The values in the following section are added to the Content Security Policy.
    # This is used to allow connections to external URLs.
    # Adding URLs that are local to your cluster is unnecessary.
    [ret."Elixir.RetWeb.Plugs.AddCSP"]
    child_src = ""
    connect_src = "demo.hubsfoundation.org *.demo.hubsfoundation.org"
    font_src = ""
    form_action = ""
    frame_src = ""
    img_src = "demo.hubsfoundation.org *.demo.hubsfoundation.org"
    manifest_src = ""
    media_src = "demo.hubsfoundation.org *.demo.hubsfoundation.org"
    script_src = ""
    style_src = ""
    worker_src = ""

    [ret."Ret.Repo.Migrations.AdminSchemaInit"]
    postgrest_password = ""

    [ret."Elixir.Ret.StatsJob"]

    [ret."Elixir.RetWeb.HealthController"]

    [ret."Elixir.RetWeb.PageController"]
    skip_cache = false
    extra_avatar_headers = ""
    extra_index_headers = ""
    extra_room_headers = ""
    extra_scene_headers = ""

    extra_avatar_html = ""
    extra_index_html = ""
    extra_room_html = ""
    extra_scene_html = ""

    extra_avatar_script = ""
    extra_index_script = ""
    extra_room_script = ""
    extra_scene_script = ""

    [ret."Elixir.Ret.Account"]
    admin_email = "<ADM_EMAIL>"

    [ret."Elixir.Ret.Coturn"]
    realm = "turkey"
    public_tls_ports = "5349"

    [web_push_encryption.vapid_details]
    subject = ""
    public_key = ""
    private_key = ""

    [run]
    hostname_dns_suffix = "turkey"

    [hackney]
    max_connections = 250

    [ret."Elixir.Ret.Meta"]
    phx_host = "<HUB_DOMAIN>"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: reticulum
  namespace: $Namespace
  annotations:
    cluster-autoscaler.kubernetes.io/safe-to-evict: "true"
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
spec:
  # BotRunnerLease has PostgreSQL fencing, but this complete profile remains singleton
  # until readiness/endpoints and the ret-pvc RWO constraint pass a separate staged
  # two-replica rollout. Manifest verification also continues to reject Reticulum HPAs.
  replicas: $RETICULUM_REPLICAS
  selector:
    matchLabels:
      app: reticulum
  minReadySeconds: 15
  # Recreate preserves the current storage and operational boundary. Operators
  # must still abort on duplicate pods/endpoints until those gates are updated.
  strategy:
    type: Recreate
  revisionHistoryLimit: 1
  template:
    metadata:
      labels:
        app: reticulum
      annotations:
        yenhubs.org/bot-access-key-checksum: "$BOT_ACCESS_KEY_CHECKSUM"
        yenhubs.org/bot-runner-access-key-checksum: "$BOT_RUNNER_ACCESS_KEY_CHECKSUM"
        yenhubs.org/bot-orchestrator-access-key-checksum: "$BOT_ORCHESTRATOR_ACCESS_KEY_CHECKSUM"
        yenhubs.org/bot-runner-recovery-epoch: "$BOT_RUNNER_RECOVERY_EPOCH"
        yenhubs.org/dashboard-access-key-checksum: "$DASHBOARD_ACCESS_KEY_CHECKSUM"
        yenhubs.org/db-credential-checksum: "$DB_CREDENTIAL_CHECKSUM"
    spec:
      automountServiceAccountToken: false
      volumes:
      - name: storage
        hostPath:
          path: /tmp/ret_storage_data
          type: DirectoryOrCreate
      - name: config
        configMap:
          name: ret-config
      containers:
      - name: reticulum
        volumeMounts:
        - name: storage
          mountPath: /storage
        - name: config
          mountPath: /home/ret
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            drop:
            - ALL
          seccompProfile:
            type: RuntimeDefault
        image: $Container_Dockerhub_Username/reticulum:$Container_Tag
        resources:
          requests:
            cpu: 250m
            memory: 2Gi
          limits:
            memory: 4Gi
        ports:
        - containerPort: 9100
        imagePullPolicy: IfNotPresent
        env:
        - name: POD_IP
          valueFrom:
            fieldRef:
              fieldPath: status.podIP
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        - name: turkeyCfg_POD_NS
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: turkeyCfg_NODE_COOKIE
          valueFrom:
            secretKeyRef:
              name: configs
              key: NODE_COOKIE
        - name: turkeyCfg_HUB_DOMAIN
          valueFrom:
            secretKeyRef:
              name: configs
              key: HUB_DOMAIN
        - name: turkeyCfg_DOMAIN
          valueFrom:
            secretKeyRef:
              name: configs
              key: HUB_DOMAIN
        - name: turkeyCfg_DB_USER
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_USER
        - name: turkeyCfg_DB_PASS
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_PASS
        - name: turkeyCfg_DB_NAME
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_NAME
        - name: turkeyCfg_DB_HOST
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_HOST
        - name: turkeyCfg_DB_HOST_T
          valueFrom:
            secretKeyRef:
              name: configs
              key: DB_HOST_T
        - name: turkeyCfg_GUARDIAN_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: GUARDIAN_KEY
        - name: turkeyCfg_PERMS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: PERMS_KEY
        - name: turkeyCfg_PHX_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: PHX_KEY
        - name: turkeyCfg_SMTP_SERVER
          valueFrom:
            secretKeyRef:
              name: configs
              key: SMTP_SERVER
        - name: turkeyCfg_SMTP_PORT
          valueFrom:
            secretKeyRef:
              name: configs
              key: SMTP_PORT
        - name: turkeyCfg_SMTP_USER
          valueFrom:
            secretKeyRef:
              name: configs
              key: SMTP_USER
        - name: turkeyCfg_SMTP_PASS
          valueFrom:
            secretKeyRef:
              name: configs
              key: SMTP_PASS
        - name: turkeyCfg_ADM_EMAIL
          valueFrom:
            secretKeyRef:
              name: configs
              key: ADM_EMAIL
        - name: turkeyCfg_SKETCHFAB_API_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: SKETCHFAB_API_KEY
        - name: turkeyCfg_IMG_PROXY
          value: nearspark.$Namespace
        - name: turkeyCfg_TENOR_API_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: TENOR_API_KEY
        - name: turkeyCfg_BOT_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: BOT_ACCESS_KEY
        - name: turkeyCfg_BOT_RUNNER_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: BOT_RUNNER_ACCESS_KEY
        - name: turkeyCfg_BOT_ORCHESTRATOR_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: BOT_ORCHESTRATOR_ACCESS_KEY
        - name: turkeyCfg_BOT_RUNNER_RECOVERY_EPOCH
          value: "$BOT_RUNNER_RECOVERY_EPOCH"
        - name: turkeyCfg_MAX_ACTIVE_ROOMS
          value: "$MAX_ACTIVE_ROOMS"
        - name: turkeyCfg_DASHBOARD_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: DASHBOARD_ACCESS_KEY
        - name: turkeyCfg_YTDL_HOST
          value: "http://ytdl:5000"
        - name: turkeyCfg_PHOTOMNEMONIC
          value: "http://photomnemonic:5000"
        - name: turkeyCfg_SPEELYCAPTOR
          value: "http://speelycaptor:5000"
        - name: turkeyCfg_STORAGE_QUOTA_GB
          value: "1000"
        livenessProbe:
          httpGet:
            path: /?skipadmin
            port: 4001
            scheme: HTTP
          initialDelaySeconds: 30
          timeoutSeconds: 3
          periodSeconds: 30
        readinessProbe:
            initialDelaySeconds: 20
            httpGet:
              path: /?skipadmin
              port: 4001
              scheme: HTTP
            timeoutSeconds: 5
            periodSeconds: 5
            successThreshold: 5
            failureThreshold: 100
      - name: postgrest
        image: $Container_Dockerhub_Username/postgrest:$Container_Tag
        resources:
          requests:
            cpu: 25m
            memory: 32Mi
          limits:
            memory: 256Mi
        ports:
        - containerPort: 3000
        imagePullPolicy: IfNotPresent
        env:
        - name: PGRST_LOG_LEVEL
          value: info
        - name: PGRST_DB_SCHEMA
          value: ret0_admin
        - name: PGRST_DB_ANON_ROLE
          value: postgres
        - name: PGRST_DB_URI
          valueFrom:
            secretKeyRef:
              name: configs
              key: PGRST_DB_URI
        - name: PGRST_JWT_SECRET
          valueFrom:
            secretKeyRef:
              name: configs
              key: PGRST_JWT_SECRET
---
apiVersion: v1
kind: Service
metadata:
  name: ret
  namespace: $Namespace
spec:
  clusterIP: None
  ports:
  - name: http-reticulum
    port: 4001
    targetPort: 4001
  - name: https-reticulum
    port: 4000
    targetPort: 4000
  selector:
    app: reticulum
---
####################################################################################
################################ bot-orchestrator ##################################
####################################################################################
apiVersion: apps/v1
kind: Deployment
metadata:
  name: bot-orchestrator
  namespace: $Namespace
  annotations:
    cluster-autoscaler.kubernetes.io/safe-to-evict: "true"
    yenhubs.org/runner-activation-phase: "$BOT_RUNNER_ACTIVATION_PHASE"
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
    yenhubs.org/bot-runner-recovery-epoch: "$BOT_RUNNER_RECOVERY_EPOCH"
spec:
  replicas: $BOT_ORCHESTRATOR_REPLICAS
  # A second orchestrator must never overlap the authenticated runner lease.
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: bot-orchestrator
  template:
    metadata:
      labels:
        app: bot-orchestrator
      annotations:
        yenhubs.org/bot-orchestrator-access-key-checksum: "$BOT_ORCHESTRATOR_ACCESS_KEY_CHECKSUM"
        yenhubs.org/bot-runner-recovery-epoch: "$BOT_RUNNER_RECOVERY_EPOCH"
    spec:
      serviceAccountName: bot-orchestrator
      automountServiceAccountToken: true
      imagePullSecrets:
      - name: bot-images-pull
      containers:
      - name: bot-orchestrator
        image: $Container_Dockerhub_Username/bot-orchestrator:$Container_Tag
        securityContext:
          runAsNonRoot: true
          runAsUser: 1000
          runAsGroup: 1000
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: true
          capabilities:
            drop:
            - ALL
          seccompProfile:
            type: RuntimeDefault
        resources:
          requests:
            cpu: 25m
            memory: 128Mi
          limits:
            memory: 512Mi
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 5001
          name: http
        env:
        - name: BOT_ORCHESTRATOR_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: BOT_ORCHESTRATOR_ACCESS_KEY
        - name: OPENAI_API_KEY
          valueFrom:
            secretKeyRef:
              name: configs
              key: OPENAI_API_KEY
        - name: OPENAI_MODEL
          value: gpt-5-nano
        - name: OPENAI_TOTAL_BUDGET_MS
          value: "$OPENAI_TOTAL_BUDGET_MS"
        - name: RUNNER_AUTOSTART
          value: "true"
        - name: RUNNER_BACKEND
          value: ghost
        - name: RUNNER_BACKEND_CANARY_HUBS
          value: ""
        - name: RUNNER_SCRIPT
          value: /app/run-bot.js
        - name: BOT_RUNNER_IMAGE
          value: "$BOT_RUNNER_IMAGE"
        - name: BOT_RUNNER_RECOVERY_EPOCH
          value: "$BOT_RUNNER_RECOVERY_EPOCH"
        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.namespace
        - name: RUNNER_POD_NAMESPACE
          value: hcce-bot-runners
        - name: ORCHESTRATOR_POD_NAME
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.name
        - name: ORCHESTRATOR_POD_UID
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.uid
        - name: RUNNER_CONTROL_URL
          value: http://bot-orchestrator.$Namespace.svc.cluster.local:5001
        - name: RUNNER_POD_RECONCILE_INTERVAL_MS
          value: "5000"
        - name: RUNNER_TOKEN_TTL_SECONDS
          value: "3600"
        - name: RET_INTERNAL_ENDPOINT
          value: http://ret:4001
        - name: RET_INTERNAL_PATH
          value: /api-internal/v1/hubs/configured_with_bots
        - name: RET_INTERNAL_ACCESS_HEADER
          value: x-ret-bot-orchestrator-access-key
        - name: GHOST_RUNNER_SCRIPT
          value: /app/run-ghost-runner.js
        - name: GHOST_RAYCAST_MODE
          value: spoke_colliders
        - name: GHOST_NAVIGATION_MODE
          value: navmesh_preferred
        - name: GHOST_NAVIGATION_REQUIRE_NAVMESH
          value: "true"
        - name: GHOST_NAVIGATION_RECOVERY_RESTART_MS
          value: "30000"
        - name: GHOST_SPAWN_RECOVERY_RESTART_MS
          value: "5000"
        - name: GHOST_NAVMESH_MAX_TRIANGLES
          value: "$GHOST_NAVMESH_MAX_TRIANGLES"
        - name: GHOST_NAVMESH_MAX_ROUTE_POINTS
          value: "$GHOST_NAVMESH_MAX_ROUTE_POINTS"
        - name: GHOST_NAVMESH_MAX_SNAP_DISTANCE_M
          value: "$GHOST_NAVMESH_MAX_SNAP_DISTANCE_M"
        - name: GHOST_FEATURED_FETCH_TIMEOUT_MS
          value: "$GHOST_FEATURED_FETCH_TIMEOUT_MS"
        - name: GHOST_FEATURED_MAX_BYTES
          value: "$GHOST_FEATURED_MAX_BYTES"
        - name: GHOST_FEATURED_MAX_REDIRECTS
          value: "$GHOST_FEATURED_MAX_REDIRECTS"
        - name: GHOST_FEATURED_MAX_ENTRIES
          value: "$GHOST_FEATURED_MAX_ENTRIES"
        - name: GHOST_FEATURED_MAX_REFS
          value: "$GHOST_FEATURED_MAX_REFS"
        - name: GHOST_SCENE_FETCH_TIMEOUT_MS
          value: "10000"
        - name: GHOST_SCENE_MAX_BYTES
          value: "67108864"
        - name: GHOST_SCENE_MAX_JSON_BYTES
          value: "4194304"
        - name: GHOST_SCENE_MAX_NODES
          value: "50000"
        - name: GHOST_SCENE_MAX_EDGES
          value: "200000"
        - name: HUBS_BASE_URL
          value: https://$HUB_DOMAIN
        - name: RET_SYNC_TIMEOUT_MS
          value: "5000"
        - name: RET_SNAPSHOT_TTL_MS
          value: "120000"
        - name: RUNNER_CONFIG_ACK_TIMEOUT_MS
          value: "15000"
        - name: RUNNER_STARTUP_GRACE_MS
          # Includes first scheduling and a cold private-image pull.
          value: "180000"
        - name: RUNNER_STALE_RESTART_MS
          value: "30000"
        - name: RUNNER_TERMINAL_RECOVERY_GRACE_MS
          value: "15000"
        - name: RUNNER_WATCHDOG_INTERVAL_MS
          value: "5000"
        - name: RUNNER_RESTART_BASE_MS
          value: "3000"
        - name: RUNNER_RESTART_MAX_MS
          value: "60000"
        - name: RUNNER_STABLE_RESET_MS
          value: "30000"
        - name: RUNNER_TERMINATION_GRACE_MS
          value: "10000"
        - name: RUNNER_KILL_GRACE_MS
          value: "5000"
        - name: MAX_ACTIVE_ROOMS
          value: "$MAX_ACTIVE_ROOMS"
        - name: MAX_BOTS_PER_ROOM
          value: "$MAX_BOTS_PER_ROOM"
        volumeMounts:
        - name: bot-orchestrator-tmp
          mountPath: /tmp
        livenessProbe:
          httpGet:
            path: /health
            port: 5001
          initialDelaySeconds: 10
          periodSeconds: 15
        readinessProbe:
          httpGet:
            path: /transport-ready
            port: 5001
          initialDelaySeconds: 5
          periodSeconds: 10
      volumes:
      - name: bot-orchestrator-tmp
        emptyDir:
          sizeLimit: 256Mi
---
apiVersion: v1
kind: Service
metadata:
  name: bot-orchestrator
  namespace: $Namespace
spec:
  selector:
    app: bot-orchestrator
  ports:
  - name: http
    protocol: TCP
    port: 5001
    targetPort: 5001
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: bot-orchestrator
  namespace: $Namespace
automountServiceAccountToken: true
imagePullSecrets:
- name: bot-images-pull
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: bot-runner
  namespace: hcce-bot-runners
automountServiceAccountToken: false
imagePullSecrets:
- name: bot-images-pull
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: bot-orchestrator-runner-pods
  namespace: $Namespace
  annotations:
    yenhubs.org/legacy-runner-authority: neutralized
rules: []
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: bot-orchestrator-runner-pods
  namespace: $Namespace
  annotations:
    yenhubs.org/legacy-runner-authority: neutralized
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: bot-orchestrator-runner-pods
subjects:
- kind: ServiceAccount
  name: bot-orchestrator
  namespace: $Namespace
---
apiVersion: v1
kind: ResourceQuota
metadata:
  name: bot-runner-capacity
  namespace: hcce-bot-runners
spec:
  hard:
    pods: "10"
    requests.cpu: 250m
    requests.memory: 1280Mi
    limits.cpu: "5"
    limits.memory: 5Gi
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: bot-orchestrator-runner-pods
  namespace: hcce-bot-runners
  annotations:
    yenhubs.org/runner-activation-phase: "$BOT_RUNNER_ACTIVATION_PHASE"
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
rules:
- apiGroups:
  - ""
  resources:
  - pods
  verbs:
  - create
  - delete
  - get
  - list
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: bot-orchestrator-runner-pods
  namespace: hcce-bot-runners
  annotations:
    yenhubs.org/runner-activation-phase: "$BOT_RUNNER_ACTIVATION_PHASE"
    yenhubs.org/bot-runner-recovery-phase: "$BOT_RUNNER_RECOVERY_PHASE"
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: bot-orchestrator-runner-pods
subjects:
- kind: ServiceAccount
  name: bot-orchestrator
  namespace: $Namespace
---
apiVersion: admissionregistration.k8s.io/v1
kind: ValidatingAdmissionPolicy
metadata:
  name: bot-runner-pods.yenhubs.org
spec:
  failurePolicy: Fail
  matchConstraints:
    matchPolicy: Equivalent
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: hcce-bot-runners
    objectSelector: {}
    resourceRules:
    - apiGroups:
      - ""
      apiVersions:
      - v1
      operations:
      - CREATE
      - DELETE
      resources:
      - pods
      scope: Namespaced
  variables:
  - name: pod
    expression: >-
      request.operation == 'DELETE' ? oldObject : object
  - name: labels
    expression: variables.pod.metadata.labels
  - name: annotations
    expression: variables.pod.metadata.annotations
  - name: container
    expression: variables.pod.spec.containers[0]
  - name: env
    expression: variables.container.env
  - name: parentPodName
    expression: >-
      request.operation == 'DELETE' ? '' : request.userInfo.extra['authentication.kubernetes.io/pod-name'][0]
  - name: parentPodUid
    expression: >-
      request.operation == 'DELETE' ? '' : request.userInfo.extra['authentication.kubernetes.io/pod-uid'][0]
  validations:
  - expression: >-
      request.namespace == 'hcce-bot-runners' &&
      (request.operation == 'DELETE' ||
       (request.userInfo.username == 'system:serviceaccount:$Namespace:bot-orchestrator' &&
        has(request.userInfo.extra) &&
        'authentication.kubernetes.io/pod-name' in request.userInfo.extra &&
        size(request.userInfo.extra['authentication.kubernetes.io/pod-name']) == 1 &&
        'authentication.kubernetes.io/pod-uid' in request.userInfo.extra &&
        size(request.userInfo.extra['authentication.kubernetes.io/pod-uid']) == 1))
    message: runner Pod mutations require the exact Pod-bound parent ServiceAccount principal
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (variables.pod.apiVersion == 'v1' &&
      variables.pod.kind == 'Pod' &&
      variables.pod.metadata.namespace == 'hcce-bot-runners' &&
      size(variables.labels) == 4 &&
      variables.labels['app'] == 'bot-runner' &&
      variables.labels['yenhubs.org/managed-by'] == 'bot-orchestrator' &&
      variables.labels['yenhubs.org/room-key'].matches('^[0-9a-f]{20}$') &&
      variables.labels['yenhubs.org/generation'].matches('^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$') &&
      variables.pod.metadata.name == 'bot-runner-' + variables.labels['yenhubs.org/room-key'].substring(0, 16) + '-' + variables.labels['yenhubs.org/generation'].substring(0, 8) &&
      size(variables.annotations) == 4 &&
      variables.annotations['yenhubs.org/expires-at'].matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.000Z$') &&
      variables.annotations['yenhubs.org/parent-namespace'] == '$Namespace' &&
      variables.annotations['yenhubs.org/parent-name'].matches('^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$') &&
      variables.annotations['yenhubs.org/parent-uid'].matches('^[A-Za-z0-9_.:-]{1,128}$') &&
      variables.annotations['yenhubs.org/parent-name'] == variables.parentPodName &&
      variables.annotations['yenhubs.org/parent-uid'] == variables.parentPodUid &&
      (!has(variables.pod.metadata.ownerReferences) || size(variables.pod.metadata.ownerReferences) == 0) &&
      (!has(variables.pod.metadata.finalizers) || size(variables.pod.metadata.finalizers) == 0) &&
      (!has(variables.pod.metadata.generateName) || variables.pod.metadata.generateName == ''))
    message: runner Pod metadata, parent binding, labels, and annotations must match the exact contract
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (variables.pod.spec.serviceAccountName == 'bot-runner' &&
      variables.pod.spec.automountServiceAccountToken == false &&
      size(variables.pod.spec.imagePullSecrets) == 1 &&
      variables.pod.spec.imagePullSecrets[0].name == 'bot-images-pull' &&
      variables.pod.spec.enableServiceLinks == false &&
      variables.pod.spec.restartPolicy == 'Never' &&
      variables.pod.spec.terminationGracePeriodSeconds == 10 &&
      variables.pod.spec.activeDeadlineSeconds == 3600 &&
      (!has(variables.pod.spec.hostNetwork) || variables.pod.spec.hostNetwork == false) &&
      (!has(variables.pod.spec.hostPID) || variables.pod.spec.hostPID == false) &&
      (!has(variables.pod.spec.hostIPC) || variables.pod.spec.hostIPC == false) &&
      (!has(variables.pod.spec.shareProcessNamespace) || variables.pod.spec.shareProcessNamespace == false) &&
      variables.pod.spec.dnsPolicy == 'ClusterFirst' &&
      variables.pod.spec.schedulerName == 'default-scheduler' &&
      (!has(variables.pod.spec.serviceAccount) || variables.pod.spec.serviceAccount == 'bot-runner'))
    message: runner Pod service account, deadline, scheduling defaults, and host isolation must match the exact contract
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (variables.pod.spec.securityContext.runAsNonRoot == true &&
      variables.pod.spec.securityContext.runAsUser == 10001 &&
      variables.pod.spec.securityContext.runAsGroup == 10001 &&
      variables.pod.spec.securityContext.fsGroup == 10001 &&
      variables.pod.spec.securityContext.seccompProfile.type == 'RuntimeDefault' &&
      !has(variables.pod.spec.securityContext.seccompProfile.localhostProfile) &&
      variables.pod.spec.securityContext.appArmorProfile.type == 'RuntimeDefault' &&
      !has(variables.pod.spec.securityContext.appArmorProfile.localhostProfile) &&
      !has(variables.pod.spec.securityContext.fsGroupChangePolicy) &&
      !has(variables.pod.spec.securityContext.seLinuxChangePolicy) &&
      !has(variables.pod.spec.securityContext.seLinuxOptions) &&
      (!has(variables.pod.spec.securityContext.supplementalGroups) || size(variables.pod.spec.securityContext.supplementalGroups) == 0) &&
      !has(variables.pod.spec.securityContext.supplementalGroupsPolicy) &&
      (!has(variables.pod.spec.securityContext.sysctls) || size(variables.pod.spec.securityContext.sysctls) == 0) &&
      !has(variables.pod.spec.securityContext.windowsOptions))
    message: runner Pod security context must match the restricted UID, seccomp, and AppArmor contract
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (size(variables.pod.spec.containers) == 1 &&
      (!has(variables.pod.spec.initContainers) || size(variables.pod.spec.initContainers) == 0) &&
      (!has(variables.pod.spec.ephemeralContainers) || size(variables.pod.spec.ephemeralContainers) == 0) &&
      !has(variables.pod.spec.affinity) &&
      !has(variables.pod.spec.dnsConfig) &&
      (!has(variables.pod.spec.hostAliases) || size(variables.pod.spec.hostAliases) == 0) &&
      !has(variables.pod.spec.hostname) &&
      !has(variables.pod.spec.hostnameOverride) &&
      !has(variables.pod.spec.hostUsers) &&
      !has(variables.pod.spec.nodeName) &&
      (!has(variables.pod.spec.nodeSelector) || size(variables.pod.spec.nodeSelector) == 0) &&
      !has(variables.pod.spec.os) &&
      !has(variables.pod.spec.overhead) &&
      (!has(variables.pod.spec.priority) || variables.pod.spec.priority == 0) &&
      (!has(variables.pod.spec.preemptionPolicy) || variables.pod.spec.preemptionPolicy == 'PreemptLowerPriority') &&
      (!has(variables.pod.spec.priorityClassName) || variables.pod.spec.priorityClassName == '') &&
      (!has(variables.pod.spec.readinessGates) || size(variables.pod.spec.readinessGates) == 0) &&
      (!has(variables.pod.spec.resourceClaims) || size(variables.pod.spec.resourceClaims) == 0) &&
      !has(variables.pod.spec.resources) &&
      !has(variables.pod.spec.runtimeClassName) &&
      (!has(variables.pod.spec.schedulingGates) || size(variables.pod.spec.schedulingGates) == 0) &&
      !has(variables.pod.spec.setHostnameAsFQDN) &&
      !has(variables.pod.spec.subdomain) &&
      (!has(variables.pod.spec.topologySpreadConstraints) || size(variables.pod.spec.topologySpreadConstraints) == 0) &&
      (!has(variables.pod.spec.tolerations) || size(variables.pod.spec.tolerations) == 0 ||
        (size(variables.pod.spec.tolerations) == 2 &&
         variables.pod.spec.tolerations.all(t,
           t.operator == 'Exists' && t.effect == 'NoExecute' && t.tolerationSeconds == 300 &&
           (t.key == 'node.kubernetes.io/not-ready' || t.key == 'node.kubernetes.io/unreachable')))))
    message: runner Pod may not select nodes, runtime classes, devices, claims, injectors, or auxiliary containers
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (variables.container.name == 'bot-runner' &&
      variables.container.image == '$BOT_RUNNER_IMAGE' &&
      variables.container.imagePullPolicy == 'Always' &&
      variables.container.command == ['node', '/app/run-ghost-runner.js'] &&
      size(variables.container.args) == 5 &&
      variables.container.args[0] == '--url' &&
      variables.container.args[1] == 'https://$HUB_DOMAIN' &&
      variables.container.args[2] == '--room' &&
      variables.container.args[3].matches('^[A-Za-z0-9_-]{1,64}$') &&
      variables.container.args[4] == '--runner')
    message: runner image, command, and arguments must match the immutable runtime contract
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (size(variables.env) == 23 &&
      variables.env[0].name == 'GHOST_FEATURED_FETCH_TIMEOUT_MS' && variables.env[0].value == '$GHOST_FEATURED_FETCH_TIMEOUT_MS' && !has(variables.env[0].valueFrom) &&
      variables.env[1].name == 'GHOST_FEATURED_MAX_BYTES' && variables.env[1].value == '$GHOST_FEATURED_MAX_BYTES' && !has(variables.env[1].valueFrom) &&
      variables.env[2].name == 'GHOST_FEATURED_MAX_ENTRIES' && variables.env[2].value == '$GHOST_FEATURED_MAX_ENTRIES' && !has(variables.env[2].valueFrom) &&
      variables.env[3].name == 'GHOST_FEATURED_MAX_REDIRECTS' && variables.env[3].value == '$GHOST_FEATURED_MAX_REDIRECTS' && !has(variables.env[3].valueFrom) &&
      variables.env[4].name == 'GHOST_FEATURED_MAX_REFS' && variables.env[4].value == '$GHOST_FEATURED_MAX_REFS' && !has(variables.env[4].valueFrom) &&
      variables.env[5].name == 'GHOST_NAVIGATION_MODE' && variables.env[5].value == 'navmesh_preferred' && !has(variables.env[5].valueFrom) &&
      variables.env[6].name == 'GHOST_NAVIGATION_RECOVERY_RESTART_MS' && variables.env[6].value == '30000' && !has(variables.env[6].valueFrom) &&
      variables.env[7].name == 'GHOST_NAVIGATION_REQUIRE_NAVMESH' && variables.env[7].value == 'true' && !has(variables.env[7].valueFrom) &&
      variables.env[8].name == 'GHOST_NAVMESH_MAX_ROUTE_POINTS' && variables.env[8].value == '$GHOST_NAVMESH_MAX_ROUTE_POINTS' && !has(variables.env[8].valueFrom) &&
      variables.env[9].name == 'GHOST_NAVMESH_MAX_SNAP_DISTANCE_M' && variables.env[9].value == '$GHOST_NAVMESH_MAX_SNAP_DISTANCE_M' && !has(variables.env[9].valueFrom) &&
      variables.env[10].name == 'GHOST_NAVMESH_MAX_TRIANGLES' && variables.env[10].value == '$GHOST_NAVMESH_MAX_TRIANGLES' && !has(variables.env[10].valueFrom) &&
      variables.env[11].name == 'GHOST_RAYCAST_MODE' && variables.env[11].value == 'spoke_colliders' && !has(variables.env[11].valueFrom) &&
      variables.env[12].name == 'GHOST_SCENE_FETCH_TIMEOUT_MS' && variables.env[12].value == '10000' && !has(variables.env[12].valueFrom) &&
      variables.env[13].name == 'GHOST_SCENE_MAX_BYTES' && variables.env[13].value == '67108864' && !has(variables.env[13].valueFrom) &&
      variables.env[14].name == 'GHOST_SCENE_MAX_EDGES' && variables.env[14].value == '200000' && !has(variables.env[14].valueFrom) &&
      variables.env[15].name == 'GHOST_SCENE_MAX_JSON_BYTES' && variables.env[15].value == '4194304' && !has(variables.env[15].valueFrom) &&
      variables.env[16].name == 'GHOST_SCENE_MAX_NODES' && variables.env[16].value == '50000' && !has(variables.env[16].valueFrom) &&
      variables.env[17].name == 'GHOST_SPAWN_RECOVERY_RESTART_MS' && variables.env[17].value == '5000' && !has(variables.env[17].valueFrom) &&
      variables.env[18].name == 'BOT_RUNNER_GENERATION_TOKEN' && variables.env[18].value.matches('^v1\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]{43}$') && !has(variables.env[18].valueFrom) &&
      variables.env[19].name == 'RUNNER_PROCESS_GENERATION' && variables.env[19].value == variables.labels['yenhubs.org/generation'] && !has(variables.env[19].valueFrom) &&
      variables.env[20].name == 'RUNNER_LEASE_HOLDER_ID' && variables.env[20].value == variables.annotations['yenhubs.org/parent-uid'] && !has(variables.env[20].valueFrom) &&
      variables.env[21].name == 'RUNNER_CONTROL_URL' && variables.env[21].value == 'http://bot-orchestrator.$Namespace.svc.cluster.local:5001' && !has(variables.env[21].valueFrom) &&
      variables.env[22].name == 'RUNNER_POD_UID' && !has(variables.env[22].value) &&
      variables.env[22].valueFrom.fieldRef.apiVersion == 'v1' &&
      variables.env[22].valueFrom.fieldRef.fieldPath == 'metadata.uid' &&
      !has(variables.env[22].valueFrom.configMapKeyRef) &&
      !has(variables.env[22].valueFrom.fileKeyRef) &&
      !has(variables.env[22].valueFrom.resourceFieldRef) &&
      !has(variables.env[22].valueFrom.secretKeyRef))
    message: runner environment must be the exact non-secret allowlist with generation and holder binding
    reason: Forbidden
  - expression: >-
      request.operation == 'DELETE' ||
      (variables.container.securityContext.runAsNonRoot == true &&
      variables.container.securityContext.runAsUser == 10001 &&
      variables.container.securityContext.runAsGroup == 10001 &&
      variables.container.securityContext.allowPrivilegeEscalation == false &&
      variables.container.securityContext.readOnlyRootFilesystem == true &&
      variables.container.securityContext.capabilities.drop == ['ALL'] &&
      (!has(variables.container.securityContext.capabilities.add) || size(variables.container.securityContext.capabilities.add) == 0) &&
      variables.container.securityContext.seccompProfile.type == 'RuntimeDefault' &&
      !has(variables.container.securityContext.seccompProfile.localhostProfile) &&
      variables.container.securityContext.appArmorProfile.type == 'RuntimeDefault' &&
      !has(variables.container.securityContext.appArmorProfile.localhostProfile) &&
      (!has(variables.container.securityContext.privileged) || variables.container.securityContext.privileged == false) &&
      !has(variables.container.securityContext.procMount) &&
      !has(variables.container.securityContext.seLinuxOptions) &&
      !has(variables.container.securityContext.windowsOptions) &&
      !has(variables.container.envFrom) &&
      !has(variables.container.lifecycle) &&
      !has(variables.container.livenessProbe) &&
      (!has(variables.container.ports) || size(variables.container.ports) == 0) &&
      !has(variables.container.resizePolicy) &&
      !has(variables.container.restartPolicy) &&
      !has(variables.container.restartPolicyRules) &&
      !has(variables.container.startupProbe) &&
      (!has(variables.container.stdin) || variables.container.stdin == false) &&
      (!has(variables.container.stdinOnce) || variables.container.stdinOnce == false) &&
      (!has(variables.container.tty) || variables.container.tty == false) &&
      (!has(variables.container.volumeDevices) || size(variables.container.volumeDevices) == 0) &&
      !has(variables.container.workingDir) &&
